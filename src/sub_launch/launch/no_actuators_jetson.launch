<?xml version="1.0"?>
<launch>
    <!--### ASUQTR CONTROL NODE ###-->
    <node pkg="asuqtr_control_node" type="control_node.py" name="control_node" output="screen" >
        <rosparam command="load" file="$(find asuqtr_control_node)/params/limits_n_thresholds.yaml" />
        <rosparam command="load" file="$(find asuqtr_control_node)/params/cost_matrix.yaml" />
        <rosparam command="load" file="$(find asuqtr_control_node)/params/actuators_mock_signal.yaml" />
    </node>

	<!--### ASUQTR MANUAL NODE ###-->
    <node pkg="asuqtr_mission_management" type="manual_mode.py" name="manual_mode" output="screen" > 	  
        <rosparam command="load" file="$(find asuqtr_mission_management)/params/testing_mode.yaml" />
    </node>

	<!--### ASUQTR SENSOR NODE ###-->
    <node pkg="asuqtr_sensor_node" type="sensor_node.py" name="sensor_node" output="screen" />

	<!--### ASUQTR IMU NODE ###-->
    <include file="$(find vectornav)/launch/vectornav.launch"/>

	<!--### ASUQTR IO NODE ###-->
    <node pkg="asuqtr_io_node" type="io_node.py" name="io_node" output="screen" />

    <!--### ASUQTR POWER NODE ###-->
    <node pkg="asuqtr_power_node" type="power_node.py" name="power_node" output="screen" />

    <!--### FLEXBE ENGINE AND LAUNCHER ###-->
    <node pkg="flexbe_widget" type="be_launcher" name="behavior_launcher" output="log" />
    <node name="behavior_mirror" pkg="flexbe_mirror" type="behavior_mirror_sm" output="log" />
    <include file="$(find flexbe_onboard)/launch/behavior_onboard.launch"/>

    <!--### ROSBRIDGE AND VIDEO SERVER NODES FOR WEB PAGE ###-->
    <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch"/>
    <node pkg="web_video_server" type="web_video_server"  name="web_video_server" output="screen" />
    
    <!--### NVIDIA VIDEO_SOURCE NODE ###-->
	<arg name="input" default="v4l2:///dev/video0"/>
	<arg name="width" default="740"/>
	<arg name="height" default="740"/>
	<arg name="codec" default=""/>
	<arg name="framerate" default="15"/>

	<node pkg="ros_deep_learning" type="video_source" name="video_source" output="screen">
		<param name="resource" value="$(arg input)"/>
		<param name="width" value="$(arg width)"/>
		<param name="height" value="$(arg height)"/>
		<param name="loop" value="0"/>
		<param name="codec" value="$(arg codec)"/>
		<param name="framerate" value="$(arg framerate)"/>
	</node>

    <!--### NVIDIA DEEP LEARNING NODE ###-->
    <arg name="model_name" default="ssd-mobilenet-v2"/>
	<arg name="model_path" default=""/>
	<arg name="prototxt_path" default=""/>
	<arg name="class_labels_path" default=""/>
	<arg name="input_blob" default=""/>
	<arg name="output_cvg" default=""/>
	<arg name="output_bbox" default=""/>
	<arg name="overlay_flags" default="box,labels,conf"/>
	<arg name="mean_pixel_value" default="0.0"/>
	<arg name="threshold" default="0.5"/>

    <!--log level config for this noisy node-->
    <env name="ROSCONSOLE_CONFIG_FILE"
       value="$(find asuqtr_mission_management)/params/log_level.conf"/>
       
    <node pkg="ros_deep_learning" type="detectnet" name="detectnet" output="screen">
		<remap from="/detectnet/image_in" to="/video_source/raw"/>
		<param name="model_name" value="$(arg model_name)"/>
		<param name="model_path" value="$(arg model_path)"/>
		<param name="prototxt_path" value="$(arg prototxt_path)"/>
		<param name="class_labels_path" value="$(arg class_labels_path)"/>
		<param name="input_blob" value="$(arg input_blob)"/>
		<param name="output_cvg" value="$(arg output_cvg)"/>
		<param name="output_bbox" value="$(arg output_bbox)"/>
		<param name="overlay_flags" value="$(arg overlay_flags)"/>
		<param name="mean_pixel_value" value="$(arg mean_pixel_value)"/>
		<param name="threshold" value="$(arg threshold)"/>
    </node>
</launch>
