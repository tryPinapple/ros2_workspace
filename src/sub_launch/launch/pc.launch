<?xml version="1.0"?>
<launch>
    <!--### ASUQTR CONTROL NODE ###-->
    <node pkg="asuqtr_control_node" type="control_node.py" name="control_node" output="screen" >
        <rosparam command="load" file="$(find asuqtr_control_node)/params/limits_n_thresholds.yaml" />
        <rosparam command="load" file="$(find asuqtr_control_node)/params/cost_matrix.yaml" />
        <rosparam command="load" file="$(find asuqtr_control_node)/params/actuators_mock_signal.yaml" />
    </node>

    <!--### ASUQTR MANUAL NODE ###-->
    <node pkg="asuqtr_mission_management" type="manual_mode.py" name="manual_mode" output="screen" > 	  
        <rosparam command="load" file="$(find asuqtr_mission_management)/params/testing_mode.yaml" />
    </node>

    <!--### ASUQTR IMU NODE ###-->
    <include file="$(find vectornav)/launch/vectornav.launch"/>

    <!--### ASUQTR POWER NODE ###-->
    <node pkg="asuqtr_power_node" type="power_node.py" name="power_node" output="screen" />

    <!--### FLEXBE ENGINE AND LAUNCHER ###-->
    <node pkg="flexbe_widget" type="be_launcher" name="behavior_launcher" output="log" />
    <node name="behavior_mirror" pkg="flexbe_mirror" type="behavior_mirror_sm" output="log" />
    <include file="$(find flexbe_onboard)/launch/behavior_onboard.launch"/>

    <!--### ROSBRIDGE NODE FOR WEB PAGE ###-->
    <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch"/>
    
</launch>
