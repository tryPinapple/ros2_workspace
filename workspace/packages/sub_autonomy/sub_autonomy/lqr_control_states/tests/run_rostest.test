<launch>
        <arg name="pkg" value="lqr_control_states" />
        <arg name="path" value="$(find lqr_control_states)/tests" />

        <include file="$(find flexbe_testing)/test/flexbe_rostest.test">
       		<arg name="package" value="$(arg pkg)" />
                <arg name="testcases" value="

                 	$(arg path)/increment_pitch_5_deg.test
		 	$(arg path)/increment_roll_5_deg.test	
       		 	$(arg path)/increment_yaw_5_deg.test
		 	$(arg path)/increment_x_2_m.test
		 	$(arg path)/increment_y_2_m.test
		 	$(arg path)/increment_z_2_m.test
		 	$(arg path)/set_absolute_pitch_to_45.test
		 	$(arg path)/set_absolute_roll_to_45.test
		 	$(arg path)/set_absolute_yaw_to_45.test
		 	$(arg path)/time_x_forward_backward_3s_30%.test
		 	$(arg path)/time_x_forward_backward_3s_30%.test
	                 

                " />
        </include>
</launch>
